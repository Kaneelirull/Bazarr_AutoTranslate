# Bazarr Connection Settings (REQUIRED)
BAZARR_HOSTNAME=localhost:6767
BAZARR_APIKEY=your_bazarr_api_key_here

# Media Path (REQUIRED - path to your movies/TV shows)
MEDIA_PATH=/path/to/your/media

# Translation Languages
FIRST_LANG=et
SECOND_LANG=sv

# Lingarr (local AI translation — runs as a separate container)
# Set LINGARR_HOSTNAME so the script can health-check Lingarr on startup.
# Configure Lingarr as translation provider in Bazarr UI: Settings > Providers > Lingarr
LINGARR_HOSTNAME=http://lingarr:8080
LINGARR_APIKEY=

# Timezone
TZ=Europe/Tallinn

# Processing Settings (tuned for local AI — no external rate limits)
MAX_PARALLEL_TRANSLATIONS=4
TRANSLATE_DELAY=0.1
CHECK_INTERVAL=300
TRANSLATION_VERIFY_TIMEOUT=600

# API Connection Settings
API_TIMEOUT=2400
CONNECT_TIMEOUT=10

# Cleanup Settings
CLEANUP_TIME=04:00
CLEANUP_ROOT=/media
# For multiple directories, separate with colon: /media/movies:/media/tv:/media/anime
CLEANUP_MIN_CONFIDENCE=0.70
CLEANUP_MIN_CHARS=200
