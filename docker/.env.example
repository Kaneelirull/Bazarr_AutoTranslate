# Bazarr Connection (REQUIRED)
BAZARR_URL=http://localhost:6767
BAZARR_API_KEY=your_bazarr_api_key_here

# Lingarr Connection (REQUIRED — direct translation API)
LINGARR_URL=http://lingarr:8080
LINGARR_API_KEY=

# Media path (mounted as /media inside the container)
MEDIA_PATH=/path/to/your/media

# Languages to manage — comma-separated, first in list = highest source priority
LANGUAGES=en,et,sv

# Timezone
TZ=Europe/Tallinn

# Parallel translation workers (1 = sequential)
PARALLEL_TRANSLATES=1

# How often to re-scan Bazarr for missing subtitles (seconds, starts after Bazarr sync)
CHECK_INTERVAL=1200

# How long to wait for each Lingarr translation job (seconds, extended by subtitle length)
POLL_TIMEOUT=600

# How often to poll Lingarr job status (seconds)
POLL_INTERVAL=20

# HTTP connect timeout (seconds)
CONNECT_TIMEOUT=10

# Resubmit cooldown — avoid re-translating the same item too soon (seconds)
RESUBMIT_COOLDOWN=3600

# Post-cycle Bazarr subtitle scan
SYNC_TIMEOUT=600
SYNC_POLL_INTERVAL=15
SYNC_START_TIMEOUT=30

# Per-file cleanup after translation (comma-separated target language codes)
CLEANUP_LANGUAGES=et
CLEANUP_SCAN_EXISTING=true
CLEANUP_SCAN_INTERVAL=21600
CLEANUP_SCAN_DRY_RUN=false
CLEANUP_PRUNE_EXTRA_LANGUAGES=true
CLEANUP_PRUNE_ACTION=quarantine
CLEANUP_PRUNE_SPECIAL_SIDECARS=true
CLEANUP_PRUNE_UNKNOWN_SIDECARS=false
CLEANUP_SOURCELESS_LINE_ONLY_ACTION=warn
CLEANUP_QUARANTINE_HOLD_DAYS=30
CLEANUP_ROOT=/media
CLEANUP_ACTION=quarantine
CLEANUP_QUARANTINE_DIR=/config/quarantine
CLEANUP_MIN_CONFIDENCE=0.70
CLEANUP_MIN_CHARS=200
CLEANUP_MAX_UNIQUE_RATIO=0.15
CLEANUP_MAX_CYRILLIC_RATIO=0.05
CLEANUP_MAX_CJK_RATIO=0.05
CLEANUP_MAX_LATIN_RATIO=0.80
CLEANUP_MIN_LETTERS_FOR_SCRIPT=20
CLEANUP_MAX_CUE_LINES=4
CLEANUP_MAX_CUE_CHARS=500
CLEANUP_MAX_EXPANSION_RATIO=4.0
CLEANUP_MAX_EXPANSION_CHARS=300
CLEANUP_MAX_SOURCE_SIMILARITY=0.92
CLEANUP_REPAIR_ENABLED=true
CLEANUP_MAX_REPAIR_ATTEMPTS=2
CLEANUP_REPAIR_CONTEXT_LINES=5
CLEANUP_FORMAT_REPAIR_ENABLED=true
CLEANUP_REPAIR_WORKERS=1
CLEANUP_REPAIR_QUEUE_MAX=100
CLEANUP_UNDERSIZED_ENABLED=true
CLEANUP_MIN_MEDIA_DURATION=900
CLEANUP_MIN_CUES_PER_MINUTE=1.5
CLEANUP_MIN_TEXT_CHARS_PER_MINUTE=40
CLEANUP_MIN_BYTES_PER_MINUTE=100
CLEANUP_MIN_TIMELINE_COVERAGE=0.60
CLEANUP_UNDERSIZED_REQUIRED_SIGNALS=3
CLEANUP_FFPROBE_TIMEOUT=15

# Retain quarantine files, reports, application logs, and validation history for 30 days
RETENTION_DAYS=30
RETENTION_CHECK_INTERVAL=3600
LOG_DIR=/var/log/bazarr-autotranslate

# Read-only manual-refresh status dashboard (trusted LAN; no authentication)
STATUS_ENABLED=true
STATUS_BIND=0.0.0.0
STATUS_PORT=8765
STATUS_HISTORY_RETENTION_DAYS=30
STATUS_RECENT_LIMIT=20
