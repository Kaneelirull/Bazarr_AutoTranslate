# Bazarr Connection (REQUIRED)
BAZARR_URL=http://localhost:6767
BAZARR_API_KEY=your_bazarr_api_key_here

# Media path (mounted as /media inside the container)
MEDIA_PATH=/path/to/your/media

# Languages to manage — comma-separated, first in list = highest source priority
# The script will translate FROM any available language TO any missing one.
LANGUAGES=en,et,sv

# Lingarr (local AI translation — configure as provider in Bazarr UI)
LINGARR_URL=http://lingarr:8080
LINGARR_API_KEY=

# Timezone
TZ=Europe/Tallinn

# Parallel translation workers (1 = sequential)
PARALLEL_TRANSLATES=1

# How often to re-scan Bazarr for missing subtitles (seconds)
CHECK_INTERVAL=1200

# How long to wait for each translated subtitle to appear in Bazarr (seconds)
POLL_TIMEOUT=600

# How often to poll during that wait (seconds)
POLL_INTERVAL=20

# HTTP connect timeout (seconds)
CONNECT_TIMEOUT=10

# Cleanup job settings (run by entrypoint.sh cron, not the Python script)
CLEANUP_TIME=04:00
CLEANUP_ROOT=/media
# Multiple dirs: /media/movies:/media/tv:/media/anime
CLEANUP_MIN_CONFIDENCE=0.70
CLEANUP_MIN_CHARS=200
