# Bazarr Connection Settings (REQUIRED)
BAZARR_HOSTNAME=localhost:6767
BAZARR_APIKEY=your_bazarr_api_key_here

# Media Path (REQUIRED - path to your movies/TV shows)
MEDIA_PATH=/path/to/your/media

# Translation Languages
FIRST_LANG=et
SECOND_LANG=sv

# Processing Settings
MAX_PARALLEL_TRANSLATIONS=2
TRANSLATE_DELAY=0.3
CHECK_INTERVAL=300

# API Connection Settings
API_TIMEOUT=2400
CONNECT_TIMEOUT=10

# Cleanup Settings
CLEANUP_TIME=04:00
CLEANUP_ROOT=/media
# For multiple directories, separate with colon: /media/movies:/media/tv:/media/anime
CLEANUP_MIN_CONFIDENCE=0.70
CLEANUP_MIN_CHARS=200
